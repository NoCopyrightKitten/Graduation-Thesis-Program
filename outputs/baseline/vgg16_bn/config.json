{
  "model_key": "vgg16_bn",
  "seed": 42,
  "batch_size": 128,
  "epochs": 20,
  "lr": 0.001,
  "weight_decay": 0.0001,
  "num_workers": 4,
  "use_pretrained": true,
  "img_size": 224,
  "pad_fill": 0,
  "normalize_mean": [
    0.485,
    0.456,
    0.406
  ],
  "normalize_std": [
    0.229,
    0.224,
    0.225
  ],
  "flip_p": 0.5,
  "color_jitter": {
    "brightness": 0.2,
    "contrast": 0.2,
    "saturation": 0.2,
    "hue": 0.02
  }
}